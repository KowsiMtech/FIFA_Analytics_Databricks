ules[mod]\n\n# Remove old workspace paths, add dst\nsys.path = [p for p in sys.path if 'FIFA_Sports_Analytics' not in p]\nsys.path.insert(0, dst)\n\nsys.exit(\n    pytest.main([\n        f'{dst}/tests',\n        '-v',\n        '--tb=short',\n        '-p', 'no:cacheprovider',\n        '--assert=plain',\n    ])\n)","commandVersion":9,"state":"error","results":{"type":"listResults","data":[{"type":"ansi","data":"\u001B[1m============================= test session starts ==============================\u001B[0m\nplatform linux -- Python 3.12.3, pytest-8.3.5, pluggy-1.5.0 -- /local_disk0/.ephemeral_nfs/envs/pythonEnv-25fe65c3-d131-4ecb-b076-008b91e29408/bin/python\nrootdir: /tmp/fifa_tests/tests\nplugins: anyio-4.6.2, typeguard-4.3.0\n\u001B[1mcollecting ... \u001B[0mcollected 2 items / 1 error\n\n==================================== ERRORS ====================================\n\u001B[31m\u001B[1m_______________________ ERROR collecting test_silver.py ________________________\u001B[0m\n\u001B[31mImportError while importing test module '/tmp/fifa_tests/tests/test_silver.py'.\nHint: make sure your test modules/packages have valid Python names.\nTraceback:\n\u001B[1m\u001B[31m/usr/lib/python3.12/importlib/__init__.py\u001B[0m:90: in import_module\n    \u001B[0m\u001B[94mreturn\u001B[39;49;00m _bootstrap._gcd_import(name[level:], package, level)\u001B[90m\u001B[39;49;00m\n\u001B[1m\u001B[31m/tmp/fifa_tests/tests/test_silver.py\u001B[0m:10: in <module>\n    \u001B[0m\u001B[94mfrom\u001B[39;49;00m \u001B[04m\u001B[96msrc\u001B[39;49;00m\u001B[04m\u001B[96m.\u001B[39;49;00m\u001B[04m\u001B[96mtransformations\u001B[39;49;00m \u001B[94mimport\u001B[39;49;00m handle_nulls, add_derived_columns, add_audit_columns\u001B[90m\u001B[39;49;00m\n\u001B[1m\u001B[31mE   ModuleNotFoundError: No module named 'src.transformations'\u001B[0m\u001B[0m\n\u001B[36m\u001B[1m=========================== short test summary info ============================\u001B[0m\n\u001B[31mERROR\u001B[0m ../../../tmp