spec))\n    # is_current is True only when no next record exists.\n    .withColumn('is_current',\n        F.when(F.col('next_version').isNull(), F.lit(True))\n         .otherwise(F.lit(False)))\n    # Convert FIFA edition numbers to calendar years.\n    .withColumn('start_year', F.col('fifa_version') + 2000)\n    .withColumn('end_year',\n        F.when(F.col('is_current'), F.lit(None))\n         .otherwise(F.col('next_version') + 2000))\n)","commandVersion":1,"state":"finished","results":{"type":"listResults","data":[],"arguments":{},"addedWidgets":{},"removedWidgets":[],"datasetInfos":[{"name":"df_with_changes","typeStr":"pyspark.sql.connect.dataframe.DataFrame","schema":{"fields":[{"metadata":{},"name":"player_id","nullable":true,"type":"integer"},{"metadata":{},"name":"player_name","nullable":true,"type":"string"},{"metadata":{},"name":"nationality","nullable":true,"type":"string"},{"metadata":{},"name":"club_name","nullable":true,"type":"string"},{"metadata":{},"name":"league_name","nullable":true,"type":"string"},{"metadata":{},"name":"overall_rating","nullable":true,"type":"integer"},{"metadata":{},"name":"market_value_eur","nullable":true,"type":"double"},{"metadata":{},"name":"fifa_version","nullable":true,"type":"integer"},{"metadata":{},"name":"prev_club","nullable":true,"type":"string"},{"metadata":{},"name":"club_changed","nullable":false,"type":"boolean"},{"metadata":{},"name":"next_version","nullable":true,"type":"integer"},{"metadata":{},"name":"is_current","nullable":false,"type":"boolean"},{"metadata":{},"name":"start_year","nullable":true,"type":"integer"},{"metadata":{},"name":"end_year","nullable":true,"type":"integer"}],"type":"struct"},"tableIdentifier":null}],"metadata":{"isDbfsCommandResult":false}},"resultDbfsStatus":"INLINED_IN_TREE","resultDbfsErrorMessage":null,"errorSummary":null,"errorTraceType":null,"error":null,"errorDetails":null,"baseErrorDetails":{"type":"baseError","stackFrames":[],"arguments":{},"addedWidgets":{},"removedWidgets"